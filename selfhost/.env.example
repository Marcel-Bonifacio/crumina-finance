# Copy to selfhost/.env and fill in. NEVER commit the real .env (it is gitignored).
# For a seamless cutover, reuse the SAME secret values from your managed host so
# existing logins/tokens keep working (otherwise users simply sign in again).
PORT=3000
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://crumina.example.com/api/auth/callback
SESSION_SECRET=long-random-string-(openssl rand -base64 48)
TOKEN_ENC_KEY=aes-256-gcm-key-(must match your managed host's value)

# --- Optional: IMAP sign-in (use ANY email provider, no Google needed) ---
# Set to 1 to show "Connect another email (IMAP)" on the login page. Self-host only;
# the managed host never enables it. Lets you sign in with Gmail / Outlook / iCloud /
# any IMAP server via an app-specific password. Credentials are stored AES-256-GCM
# encrypted in an HttpOnly cookie (no database). Needs HTTPS (or localhost) for the cookie.
IMAP_ENABLED=
